# Copie este arquivo para .env.local e preencha com os valores reais.
# O .env.local NÃO é versionado (está no .gitignore).

# --- Banco MySQL (Locaweb DBaaS) ---
DB_HOST=host.mysql.dbaas.com.br
DB_PORT=3306
DB_USER=usuario
DB_PASSWORD=senha
DB_NAME=banco
# DB_POOL=5   # (opcional) tamanho do pool de conexões

# --- Sessão ---
# Segredo para assinar o cookie de login. Gere um novo com:
#   openssl rand -hex 32
SESSION_SECRET=troque-por-um-segredo-aleatorio-de-64-hex

# --- URL pública do app (usada no link de redefinição de senha) ---
APP_URL=http://localhost:3000

# --- SMTP (envio do e-mail de "esqueci minha senha") ---
# Sem SMTP_HOST, o e-mail não é enviado; em dev o link aparece no console.
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Pierre Alexander <no-reply@pierrealexander.com.br>
