# Supabase — copie este arquivo para .env.local e preencha com as chaves do
# seu projeto (Supabase → Project Settings → API).
#
# As duas primeiras são públicas (vão para o browser, é seguro).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-aqui-a-anon-public-key

# Service role: NÃO é público. Usado só por scripts server-side. Nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key
